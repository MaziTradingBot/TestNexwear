# ---- Database (required) ----
# Local: a Postgres connection string. On Render this is injected automatically.
DATABASE_URL="postgresql://user:password@localhost:5432/nexwear?schema=public"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Auth (NextAuth) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---- Email (optional) ----
# If unset, password-reset links and contact messages are printed to the server console.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NexWear <no-reply@nexwear.com>"
CONTACT_INBOX="support@nexwear.com"
