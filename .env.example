# ---- Database (required) ----
# Local: a Postgres connection string. On Render this is injected automatically.
DATABASE_URL="postgresql://user:password@localhost:5432/nexwear?schema=public"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Auth (NextAuth) ----
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ---- Email (optional — order confirmations, password resets, contact) ----
# Option A (recommended): Resend API key — no SMTP needed, best deliverability.
#   Get one free at https://resend.com (then verify a domain, or use onboarding@resend.dev for tests).
RESEND_API_KEY=""
# Option B: your own email account's SMTP (e.g. Gmail/Outlook app password). No API service.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
# From address + contact inbox (used by both options).
SMTP_FROM="NexWear <onboarding@resend.dev>"
CONTACT_INBOX="support@nexwear.com"
# If none of the above are set, emails are safely logged to the server console.

# ---- Payments (optional — real card payments via Stripe) ----
# Without these, card checkout stays in simulation mode. Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""                    # sk_test_... (server)
STRIPE_WEBHOOK_SECRET=""                # whsec_... (from the webhook endpoint you create)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""   # pk_test_... (public; enables Stripe mode in the UI)
